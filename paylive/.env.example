# Worker PayLive (source des boutiques + destination des commandes)
WORKER_URL=https://<worker>.up.railway.app
WORKER_INTERNAL_SECRET=<le même secret que le worker>

# Browserless (navigateur distant + proxy résidentiel) — endpoint CDP de base
BROWSERLESS_WS=wss://production-sfo.browserless.io?token=TON_TOKEN&proxy=residential&proxyCountry=fr&proxySticky=true
# ou : BROWSERLESS_TOKEN=TON_TOKEN  (+ PROXY_COUNTRY=fr) et laisser BROWSERLESS_WS vide

# ms_token (rotation), séparés par des virgules — comptes jetables
MS_TOKENS=msToken1,msToken2

# Paramètres
PAYLIVE_HASHTAG=paylive
RECENT_VIDEOS=10
VIDEOS_SCAN=30
COMMENTS_PER_VIDEO=50
NAV_TIMEOUT_MS=90000
