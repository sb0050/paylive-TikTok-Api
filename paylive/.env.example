# Worker PayLive (source des boutiques + destination des commandes)
WORKER_URL=https://<worker>.up.railway.app
WORKER_INTERNAL_SECRET=<le même secret que le worker>

# Browserless (navigateur distant + proxy résidentiel)
# Rotation (recommandé) : plusieurs tokens séparés par des virgules. À chaque run
# on prend le 1er dont la conso mensuelle est < seuil (lue via l'API Browserless),
# et on bascule au suivant une fois saturé (~900/1000). Chaque token = un compte.
BROWSERLESS_TOKENS=token1,token2,token3,token4,token5
# Seuil de bascule / quota mensuel (optionnels, valeurs par défaut ci-dessous)
BROWSERLESS_USAGE_THRESHOLD=900
BROWSERLESS_USAGE_LIMIT=1000
PROXY_COUNTRY=fr
# (Optionnel) Cache de conso sur volume Railway persistant — repli si l'API usage
# est indisponible. Monter un volume (ex. sur /data) et pointer ce fichier dessus.
# Vide = désactivé (on s'appuie alors uniquement sur l'API, source de vérité).
# BROWSERLESS_STATE_FILE=/data/browserless_usage.json
# Repli si BROWSERLESS_TOKENS est vide (ancien mode, 1 seul token) :
# BROWSERLESS_WS=wss://production-sfo.browserless.io?token=TON_TOKEN&proxy=residential&proxyCountry=fr&proxySticky=true
# ou : BROWSERLESS_TOKEN=TON_TOKEN  (+ PROXY_COUNTRY=fr)

# ms_token (rotation), séparés par des virgules — comptes jetables
MS_TOKENS=msToken1,msToken2

# Paramètres
PAYLIVE_HASHTAG=paylive
RECENT_VIDEOS=10
VIDEOS_SCAN=30
COMMENTS_PER_VIDEO=50
NAV_TIMEOUT_MS=90000
